# ============================================
# xClaw 环境变量配置
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# ============================================
# LLM Provider Selection
# Supported: openai, wenxin(Baidu), qwen(Alibaba), zhipu(Zhipu AI),
#            kimi, spark(iFlytek), deepseek, step(StepFun), openrouter, xai
# ============================================
LLM_PROVIDER=openai

# ============================================
# OpenAI 配置
# 从 https://platform.openai.com 获取
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# OPENAI_API_BASE=https://api.openai.com/v1  # 可选，用于代理

# ============================================
# 百度文心一言配置
# 从 https://cloud.baidu.com 获取
# ============================================
# WENXIN_API_KEY=your_api_key
# WENXIN_SECRET_KEY=your_secret_key
# WENXIN_MODEL=ernie-bot-4  # 可选: ernie-bot-4, ernie-bot, ernie-bot-turbo

# ============================================
# 阿里通义千问配置
# 从 https://dashscope.aliyun.com 获取
# ============================================
# QWEN_API_KEY=your_api_key
# QWEN_MODEL=qwen-max  # 可选: qwen-max, qwen-plus, qwen-turbo, qwen-72b
# QWEN_API_BASE=https://dashscope.aliyuncs.com/api/v1  # 可选

# ============================================
# 智谱清言配置
# 从 https://open.bigmodel.cn 获取
# ============================================
# ZHIPU_API_KEY=your_api_key
# ZHIPU_MODEL=glm-4  # 可选: glm-4, glm-4-air, glm-4-flash(免费), glm-3-turbo

# ============================================
# Moonshot Kimi 配置
# 从 https://platform.moonshot.cn 获取
# ============================================
# KIMI_API_KEY=your_api_key
# KIMI_MODEL=kimi-latest  # 可选: kimi-latest, kimi-k2, kimi-k2-72b, kimi-k1.5

# ============================================
# 讯飞星火配置
# 从 https://xinghuo.xfyun.cn 获取
# ============================================
# SPARK_APP_ID=your_app_id
# SPARK_API_KEY=your_api_key
# SPARK_API_SECRET=your_api_secret
# SPARK_MODEL=spark-4  # 可选: spark-4, spark-3.5, spark-3.1, spark-3

# ============================================
# DeepSeek 配置
# 从 https://platform.deepseek.com 获取
# ============================================
# DEEPSEEK_API_KEY=your_api_key
# DEEPSEEK_MODEL=deepseek-chat  # 可选: deepseek-chat, deepseek-reasoner

# ============================================
# 阶跃星辰 StepFun 配置
# 从 https://platform.stepfun.com 获取
# ============================================
# STEP_API_KEY=your_api_key
# STEP_MODEL=step-2  # 可选: step-2, step-2-mini, step-1-8k, step-1-32k, step-1-128k, step-1-256k, step-1v

# ============================================
# OpenRouter Configuration (Aggregated platform)
# Get from https://openrouter.ai
# ============================================
# OPENROUTER_API_KEY=your_api_key
# OPENROUTER_MODEL=openai/gpt-4o  # Multiple models available
# OPENROUTER_SITE_URL=https://github.com/yourusername/xClaw
# OPENROUTER_SITE_NAME=xClaw

# ============================================
# xAI (Grok) Configuration
# Get from https://console.x.ai
# ============================================
# XAI_API_KEY=your_api_key
# XAI_MODEL=grok-3  # Options: grok-3, grok-3-fast, grok-3-mini, grok-3-mini-fast, grok-2, grok-2-vision

# ============================================
# Tesla Fleet API 配置
# 从 https://developer.tesla.com 获取
# ============================================
TESLA_CLIENT_ID=your_client_id_here
TESLA_CLIENT_SECRET=your_client_secret_here
TESLA_REDIRECT_URI=https://yourdomain.com/callback

# Tesla API 区域 (na = 北美, eu = 欧洲, cn = 中国)
TESLA_REGION=cn

# 车辆 VIN (可选，如只管理一辆车)
# TESLA_VIN=your_vehicle_vin

# ============================================
# 微信接入配置
# ============================================
WECHAT_MODE=mp  # mp=微信公众号, wework=企业微信, wechaty=个人微信(有风险)
WECHAT_HOST=0.0.0.0
WECHAT_PORT=8080
WECHAT_PATH=/wechat/callback

# ---- 微信公众号 (WECHAT_MODE=mp) ----
WECHAT_MP_APP_ID=your_app_id
WECHAT_MP_APP_SECRET=your_app_secret
WECHAT_MP_TOKEN=your_token
# WECHAT_MP_ENCODING_AES_KEY=your_aes_key  # 可选，用于消息加密

# ---- 企业微信 (WECHAT_MODE=wework) ----
WEWORK_CORP_ID=your_corp_id
WEWORK_CORP_SECRET=your_corp_secret
WEWORK_AGENT_ID=your_agent_id
WEWORK_TOKEN=your_token
# WEWORK_ENCODING_AES_KEY=your_aes_key  # 可选，用于消息加密

# ---- 个人微信 Wechaty (WECHAT_MODE=wechaty) ----
# ⚠️ 警告：个人微信自动化有封号风险！
# WECHATY_PUPPET=wechaty-puppet-wechat
# WECHATY_PUPPET_PADLOCAL_TOKEN=your_padlocal_token  # 如使用 padlocal

# ============================================
# Discord Bot 配置
# 从 https://discord.com/developers/applications 获取
# ============================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here  # 可选，用于调试
DISCORD_CHANNEL_ID=your_channel_id_here  # 可选，限制 Bot 响应的频道

# ============================================
# Telegram Bot 配置
# 从 @BotFather 获取
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=user1_id,user2_id  # 允许使用的用户 ID，逗号分隔

# ============================================
# Slack Bot 配置
# 从 https://api.slack.com/apps 获取
# ============================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# ============================================
# Redis 配置 (用于缓存和状态管理)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=  # 如果有密码

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json 或 text

# ============================================
# 安全设置
# ============================================
# 命令确认超时（秒）
COMMAND_CONFIRMATION_TIMEOUT=30

# 敏感操作二次确认
ENABLE_CONFIRMATION_FOR_LOCK=false
ENABLE_CONFIRMATION_FOR_UNLOCK=true
ENABLE_CONFIRMATION_FOR_REMOTE_START=true

# ============================================
# Fleet Telemetry 配置
# ============================================
FLEET_TELEMETRY_ENABLED=false
FLEET_TELEMETRY_CA_CERT_PATH=/path/to/ca.crt
FLEET_TELEMETRY_CLIENT_CERT_PATH=/path/to/client.crt
FLEET_TELEMETRY_CLIENT_KEY_PATH=/path/to/client.key
